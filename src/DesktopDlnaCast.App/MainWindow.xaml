<Window
    x:Class="DesktopDlnaCast.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopDlnaCast.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>

  <Grid>
    <Grid.Resources>
      <DataTemplate x:Key="DisplaySelectionTemplate">
        <TextBlock
            VerticalAlignment="Center"
            Text="{Binding DisplayName}"
            TextTrimming="CharacterEllipsis" />
      </DataTemplate>
      <DataTemplate x:Key="DisplayDropDownTemplate">
        <Grid Width="260" ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border
              Width="96"
              Height="54"
              Background="{ThemeResource ControlFillColorSecondaryBrush}"
              CornerRadius="4">
            <Image
                Source="{Binding Preview}"
                Stretch="Uniform" />
          </Border>
          <TextBlock
              Grid.Column="1"
              VerticalAlignment="Center"
              Text="{Binding DisplayName}"
              TextWrapping="Wrap" />
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="AspectRatioSelectionTemplate">
        <TextBlock
            VerticalAlignment="Center"
            Text="{Binding DisplayName}"
            TextTrimming="CharacterEllipsis" />
      </DataTemplate>
      <DataTemplate x:Key="AspectRatioDropDownTemplate">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Border
              Width="64"
              Height="36"
              VerticalAlignment="Center"
              Background="#101820"
              CornerRadius="3">
            <Image
                Source="{Binding IllustrationPath}"
                Stretch="Uniform" />
          </Border>
          <TextBlock
              VerticalAlignment="Center"
              Text="{Binding DisplayName}"
              TextWrapping="Wrap" />
        </StackPanel>
      </DataTemplate>
      <local:DisplayPickerTemplateSelector
          x:Key="DisplayPickerTemplateSelector"
          SelectionTemplate="{StaticResource DisplaySelectionTemplate}"
          DropDownTemplate="{StaticResource DisplayDropDownTemplate}" />
      <local:DisplayPickerTemplateSelector
          x:Key="AspectRatioTemplateSelector"
          SelectionTemplate="{StaticResource AspectRatioSelectionTemplate}"
          DropDownTemplate="{StaticResource AspectRatioDropDownTemplate}" />
    </Grid.Resources>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid x:Name="AppTitleBar" Height="32">
      <TextBlock
          x:Name="TitleBarText"
          Margin="16,0,0,0"
          VerticalAlignment="Center"
          Style="{StaticResource CaptionTextBlockStyle}" />
    </Grid>

    <ScrollViewer
        x:Name="ContentRoot"
        Grid.Row="1"
        FontSize="12"
        HorizontalScrollMode="Disabled"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
      <Grid Padding="16,0,16,12" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel MaxWidth="720" Spacing="4">
        <TextBlock x:Uid="DeviceListLabel" FontWeight="SemiBold" />
        <ComboBox
            HorizontalAlignment="Stretch"
            MinHeight="28"
            PlaceholderText="{x:Bind ViewModel.DevicePlaceholderText, Mode=OneWay}"
            ItemsSource="{x:Bind ViewModel.Devices}"
            SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
            DisplayMemberPath="DisplayName" />
      </StackPanel>

      <Border
          Grid.Row="1"
          MaxWidth="720"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource OverlayCornerRadius}"
          Padding="10">
        <Grid ColumnSpacing="12" RowSpacing="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock x:Uid="CaptureDisplayLabel" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" x:Uid="OutputResolutionLabel" FontWeight="SemiBold" />
          <ComboBox
              x:Name="DisplayPicker"
              Grid.Row="1"
              HorizontalAlignment="Stretch"
              MinHeight="28"
              IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
              ItemsSource="{x:Bind ViewModel.Displays}"
              SelectedItem="{x:Bind ViewModel.SelectedDisplay, Mode=TwoWay}"
              ItemTemplateSelector="{StaticResource DisplayPickerTemplateSelector}"
              DropDownOpened="DisplayPicker_DropDownOpened" />
          <ComboBox
              x:Name="OutputProfilePicker"
              Grid.Row="1"
              Grid.Column="1"
              HorizontalAlignment="Stretch"
              MinHeight="28"
              IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
              ItemsSource="{x:Bind ViewModel.OutputProfiles}"
              SelectedItem="{x:Bind ViewModel.SelectedOutputProfile, Mode=TwoWay}"
              DisplayMemberPath="DisplayName"
              SelectionChanged="OutputProfilePicker_SelectionChanged" />
          <TextBlock
              Grid.Row="2"
              Margin="0,4,0,0"
              x:Uid="GopIntervalLabel"
              FontWeight="SemiBold" />
          <TextBlock
              Grid.Row="2"
              Grid.Column="1"
              Margin="0,4,0,0"
              x:Uid="QualityLabel"
              FontWeight="SemiBold" />
          <ComboBox
              Grid.Row="3"
              HorizontalAlignment="Stretch"
              MinHeight="28"
              IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
              ItemsSource="{x:Bind ViewModel.GopOptions}"
              SelectedItem="{x:Bind ViewModel.SelectedGopOption, Mode=TwoWay}"
              DisplayMemberPath="DisplayName" />
          <ComboBox
              Grid.Row="3"
              Grid.Column="1"
              HorizontalAlignment="Stretch"
              MinHeight="28"
              IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
              ItemsSource="{x:Bind ViewModel.QualityOptions}"
              SelectedItem="{x:Bind ViewModel.SelectedQualityOption, Mode=TwoWay}"
              DisplayMemberPath="DisplayName" />
          <CheckBox
              Grid.Row="4"
              Margin="0,4,0,0"
              MinWidth="0"
              MinHeight="0"
              x:Uid="IncludeCursorToggle"
              IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
              IsChecked="{x:Bind ViewModel.IncludeCursor, Mode=TwoWay}" />
          <StackPanel
              Grid.Row="4"
              Grid.Column="1"
              Margin="0,4,0,0"
              Orientation="Horizontal"
              Spacing="12">
            <CheckBox
                MinWidth="0"
                MinHeight="0"
                x:Uid="IncludeAudioToggle"
                IsChecked="{x:Bind ViewModel.IncludeAudio, Mode=TwoWay}" />
            <CheckBox
                MinWidth="0"
                MinHeight="0"
                x:Uid="AudioOnlyToggle"
                IsEnabled="{x:Bind ViewModel.IsAudioOnlyEnabled, Mode=OneWay}"
                IsChecked="{x:Bind ViewModel.AudioOnly, Mode=TwoWay}" />
          </StackPanel>
          <CheckBox
              Grid.Row="5"
              MinWidth="0"
              MinHeight="0"
              x:Uid="MuteLocalPlaybackToggle"
              IsEnabled="{x:Bind ViewModel.IncludeAudio, Mode=OneWay}"
              IsChecked="{x:Bind ViewModel.MuteLocalPlayback, Mode=TwoWay}" />
          <CheckBox
              Grid.Row="5"
              Grid.Column="1"
              MinWidth="0"
              MinHeight="0"
              x:Uid="StartAtLiveEdgeToggle"
              IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
              IsChecked="{x:Bind ViewModel.StartAtLiveEdge, Mode=TwoWay}" />
          <StackPanel
              Grid.Row="6"
              Grid.ColumnSpan="2"
              Margin="0,4,0,0"
              Spacing="4">
            <TextBlock
                x:Uid="AspectRatioModeLabel"
                FontWeight="SemiBold" />
            <ComboBox
                HorizontalAlignment="Stretch"
                MinHeight="28"
                IsEnabled="{x:Bind ViewModel.IsVideoOptionsEnabled, Mode=OneWay}"
                ItemsSource="{x:Bind ViewModel.AspectRatioOptions}"
                SelectedItem="{x:Bind ViewModel.SelectedAspectRatioOption, Mode=TwoWay}"
                ItemTemplateSelector="{StaticResource AspectRatioTemplateSelector}" />
          </StackPanel>
        </Grid>
      </Border>

      <StackPanel
          Grid.Row="2"
          MaxWidth="720"
          Orientation="Horizontal"
          Spacing="8">
        <Button x:Uid="StartCastButton" Padding="12,4,12,5" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.StartCastCommand}" />
        <Button x:Uid="StopButton" Padding="12,4,12,5" Command="{x:Bind ViewModel.StopCommand}" />
        <Button x:Uid="RefreshDevicesButton" Padding="12,4,12,5" Command="{x:Bind ViewModel.RefreshCommand}" />
        <Button x:Uid="TestRendererButton" Padding="12,4,12,5" Command="{x:Bind ViewModel.TestRendererCommand}" />
      </StackPanel>

      <StackPanel
          Grid.Row="3"
          MaxWidth="720"
          Orientation="Horizontal"
          Spacing="8">
        <TextBlock
            x:Uid="VolumeLabel"
            VerticalAlignment="Center"
            FontWeight="SemiBold" />
        <Slider
            Width="240"
            Minimum="0"
            Maximum="100"
            StepFrequency="1"
            VerticalAlignment="Center"
            IsEnabled="{x:Bind ViewModel.IsVolumeAvailable, Mode=OneWay}"
            Value="{x:Bind ViewModel.Volume, Mode=TwoWay}" />
      </StackPanel>

      <Border
          Grid.Row="4"
          MaxWidth="720"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource OverlayCornerRadius}"
          Padding="10">
        <StackPanel Spacing="2">
          <TextBlock x:Uid="SessionStatusLabel" FontWeight="SemiBold" />
          <TextBlock
              Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
              TextWrapping="Wrap" />
          <TextBlock
              Text="{x:Bind ViewModel.EncoderText, Mode=OneWay}"
              FontSize="11"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      </Grid>
    </ScrollViewer>
  </Grid>
</Window>
